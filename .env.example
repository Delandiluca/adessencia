# ── Supabase ──────────────────────────────────────────────────
# Encontre em: supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PagSeguro (PagBank) ────────────────────────────────────────
# Encontre em: pagseguro.uol.com.br > Minha Conta > Preferências > Integrações
# Token da conta (backend) — NUNCA exponha no frontend
PAGSEGURO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chave pública para criptografia de cartão no frontend
NEXT_PUBLIC_PAGSEGURO_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8XXXXXXXX...
# Segredo para validar webhooks (defina após configurar no painel PagSeguro)
PAGSEGURO_WEBHOOK_SECRET=
# Use "true" para apontar para sandbox do PagSeguro durante desenvolvimento
PAGSEGURO_SANDBOX=true

# ── Resend ────────────────────────────────────────────────────
# Encontre em: resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Deve ser um domínio verificado no Resend
RESEND_FROM_EMAIL=noreply@seudominio.com.br

# ── Admin ─────────────────────────────────────────────────────
# Escolha uma senha forte para o painel administrativo
ADMIN_PASSWORD=sua-senha-segura-aqui

# ── App ───────────────────────────────────────────────────────
# URL pública do site (sem barra no final)
NEXT_PUBLIC_APP_URL=https://adessencia.vercel.app
